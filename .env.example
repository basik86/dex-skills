# RPC endpoints (used for both read queries and broadcasting transactions)
# Private keys are NOT stored here — they are passed per-request to dex_launch

# Solana (Pump.fun, LetsBonk, Moonshot)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Base (Zora, Clanker)
BASE_RPC_URL=https://mainnet.base.org

# BNB (Four.meme)
BNB_RPC_URL=https://bsc-dataseed1.binance.org

# TRON (SunPump)
TRON_FULL_HOST=https://api.trongrid.io
TRON_API_KEY=your_trongrid_api_key

# Data APIs
BITQUERY_API_KEY=your_bitquery_key
